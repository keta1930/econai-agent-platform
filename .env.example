# Server
PORT=25002
ENV=development

# Security
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=3
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL
DB_HOST=localhost
DB_PORT=25001
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=homework

# MinIO
MINIO_ENDPOINT=localhost:25003
MINIO_API_PORT=25003
MINIO_CONSOLE_PORT=25004
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=homework
MINIO_SECURE=false

# Admin account (used on first run to seed the database)
DEFAULT_ADMIN_ID=admin
DEFAULT_ADMIN_PASSWORD=changeme

# Tavily Search API (used for AI criteria generation)
TAVILY_API_KEY=tvly-your-api-key-here

# Backup (web-level per-admin export)
MAX_BACKUPS_PER_ADMIN=10

# Snapshot (system-level full backup via scripts/snapshot.sh)
SNAPSHOT_DIR=./snapshots
MAX_SNAPSHOTS=30

# Upload limits (bytes)
MAX_TEXT_SIZE=2097152
MAX_IMAGE_SIZE=10485760
