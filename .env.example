# Server
PORT=25002
ENV=development

# Security
SECRET_KEY=change-me-in-production
TOKEN_EXPIRE_HOURS=24

# PostgreSQL
DB_HOST=localhost
DB_PORT=25001
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=homework

# MinIO
MINIO_ENDPOINT=localhost:25003
MINIO_API_PORT=25003
MINIO_CONSOLE_PORT=25004
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=homework
MINIO_SECURE=false

# Admin account (used on first run to seed the database)
DEFAULT_ADMIN_ID=admin
DEFAULT_ADMIN_PASSWORD=changeme

# Default LLM model config (used on first run to seed the database)
# Supports OpenAI-compatible APIs (e.g., DeepSeek, OpenAI) or Anthropic
DEFAULT_MODEL_NAME=deepseek-chat
DEFAULT_MODEL_API_KEY=sk-your-api-key-here
DEFAULT_MODEL_BASE_URL=https://api.deepseek.com/v1
DEFAULT_MODEL_ADAPTER=openai   # openai | anthropic

# Backup
PG_CONTAINER_NAME=book-web-postgres-1

# Tavily Search API (used for AI criteria generation)
TAVILY_API_KEY=tvly-your-api-key-here
